{
  "eventhub": {
    "namespace": "eh-uks-clearpay-prod",
    "name": "transactions",
    "consumer_group": "fraud-detection-streaming-job",
    "max_events_per_trigger": 10000
  },
  "storage": {
    "account_name": "sauksfraudprod",
    "bronze_container": "bronze",
    "silver_container": "silver",
    "gold_container": "gold",
    "bronze_path": "abfss://bronze@sauksfraudprod.dfs.core.windows.net/transactions/",
    "silver_path": "abfss://silver@sauksfraudprod.dfs.core.windows.net/fraud_candidates/",
    "gold_base":   "abfss://gold@sauksfraudprod.dfs.core.windows.net",
    "checkpoint_path": "abfss://bronze@sauksfraudprod.dfs.core.windows.net/_checkpoints/fraud_stream"
  },
  "keyvault": {
    "scope": "clearpay-kv",
    "eh_connection_key": "event-hubs-connection-string",
    "pii_salt_key": "pii-hash-salt"
  },
  "streaming": {
    "trigger_interval_seconds": 10,
    "watermark_minutes": 10
  }
}
