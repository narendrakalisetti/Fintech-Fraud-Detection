{
  "name": "fraud-detection-streaming-prod",
  "tasks": [
    {
      "task_key": "fraud_stream",
      "description": "Real-time fraud detection streaming job",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 4,
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.databricks.delta.retentionDurationCheck.enabled": "false"
        },
        "azure_attributes": {
          "availability": "SPOT_WITH_FALLBACK_AZURE",
          "spot_bid_max_price": -1
        },
        "cluster_log_conf": {
          "dbfs": { "destination": "dbfs:/cluster-logs/fraud-detection" }
        }
      },
      "spark_python_task": {
        "python_file": "dbfs:/FileStore/fraud_detection/src/fraud_detection_stream.py"
      },
      "libraries": [
        { "maven": { "coordinates": "com.microsoft.azure:azure-eventhubs-spark_2.12:2.3.22" } },
        { "pypi": { "package": "delta-spark==3.1.0" } }
      ],
      "timeout_seconds": 0,
      "max_retries": 3,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": true,
      "email_notifications": {
        "on_failure": ["dataengineering@clearpay.co.uk"],
        "no_alert_for_skipped_runs": false
      }
    },
    {
      "task_key": "silver_to_gold",
      "description": "Hourly silver to gold aggregation",
      "depends_on": [],
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog"
        }
      },
      "notebook_task": {
        "notebook_path": "/Shared/FintechFraud/01_silver_to_gold",
        "base_parameters": {}
      },
      "timeout_seconds": 3600,
      "max_retries": 2
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 * * * ?",
    "timezone_id": "Europe/London",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "tags": {
    "Project": "FintechFraudDetection",
    "Compliance": "MLR2017|UKGDPR",
    "Environment": "prod"
  }
}
