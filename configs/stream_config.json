{
  "pipeline": "Fintech-FraudDetection",
  "region": "uksouth",
  "environment": "prod",
  "event_hubs": {
    "consumer_group": "$Default",
    "topic": "transactions",
    "max_events_per_trigger": 10000
  },
  "streaming": {
    "trigger_interval_seconds": 30,
    "watermark_minutes": 10,
    "output_mode": "append"
  },
  "fraud_filter": {
    "high_value_threshold_gbp": 5000.0,
    "currency": "GBP"
  },
  "gdpr": {
    "pii_hash_algorithm": "SHA-256",
    "hashed_columns": ["Customer_Account_IBAN"],
    "retention_days": 90,
    "lawful_basis": "legitimate_interests",
    "data_controller": "Fintech Corp Ltd"
  },
  "sustainability": {
    "azure_region_renewable": true,
    "net_zero_target_year": 2050,
    "notes": "UK South Azure DC runs on renewable energy sources"
  },
  "delta": {
    "silver_table_path": "abfss://silver@adlsuksfintechprod.dfs.core.windows.net/fraud_detection/high_value_transactions_delta",
    "checkpoint_path": "abfss://silver@adlsuksfintechprod.dfs.core.windows.net/_checkpoints/fraud_detection",
    "merge_schema": true
  }
}
