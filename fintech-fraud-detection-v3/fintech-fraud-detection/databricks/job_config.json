{
  "name": "ClearPay-FraudDetection-StreamingJob",
  "description": "Production streaming job: Event Hubs -> Bronze/Silver/SAR Queue. UK GDPR compliant. MLR 2017 compliant.",
  "tags": {
    "project": "ClearPay-FraudDetection",
    "environment": "prod",
    "team": "data-engineering",
    "compliance": "gdpr-mlr2017",
    "region": "uksouth"
  },
  "job_clusters": [
    {
      "job_cluster_key": "fraud-detection-cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 4,
        "autoscale": {
          "min_workers": 2,
          "max_workers": 8
        },
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.sql.adaptive.enabled": "true",
          "spark.databricks.delta.optimizeWrite.enabled": "true"
        },
        "azure_attributes": {
          "availability": "SPOT_WITH_FALLBACK_AZURE",
          "spot_bid_max_price": -1
        },
        "cluster_log_conf": {
          "dbfs": { "destination": "dbfs:/cluster-logs/fraud-detection" }
        },
        "autotermination_minutes": 20,
        "policy_id": "clearplay-auto-terminate-policy"
      }
    }
  ],
  "tasks": [
    {
      "task_key": "fraud_detection_stream",
      "description": "Main streaming pipeline: Event Hubs -> Bronze, Silver, SAR Queue",
      "job_cluster_key": "fraud-detection-cluster",
      "spark_python_task": {
        "python_file": "dbfs:/clearplay/src/fraud_detection_stream.py",
        "parameters": []
      },
      "libraries": [
        {"pypi": {"package": "azure-eventhub==5.11.7"}},
        {"pypi": {"package": "delta-spark==3.1.0"}}
      ],
      "timeout_seconds": 0,
      "max_retries": 3,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "silver_to_gold",
      "description": "Hourly: Silver fraud candidates -> Gold KPIs + SAR Queue summary",
      "depends_on": [],
      "job_cluster_key": "fraud-detection-cluster",
      "notebook_task": {
        "notebook_path": "/EnergyZero/01_silver_to_gold",
        "base_parameters": {
          "environment": "prod"
        }
      },
      "timeout_seconds": 3600
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 * * * ?",
    "timezone_id": "Europe/London",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": ["data-platform-team@clearpay.co.uk", "mlro@clearpay.co.uk"],
    "on_success": []
  },
  "max_concurrent_runs": 1
}
